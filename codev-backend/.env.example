# LiteLLM proxy base URL (no trailing slash required)
API_URL=https://litellm.example.com

# LiteLLM admin/master token used to call /user/info, /user/new, /key/generate
AUTH_TOKEN=sk-litellm-admin-token

# OIDC userinfo endpoint used to verify the CLI's SSO access token
SSO_USERINFO_URL=https://netmind.viettel.vn/sso-wrapper/userinfo

# HTTP port the backend listens on (default: 8787)
PORT=8787
