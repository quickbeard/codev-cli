{
  "name": "codev-ai",
  "version": "0.1.5",
  "description": "CoDev — AI Coding Agent Hub. Install, configure, and manage multiple AI coding agents.",
  "keywords": [
    "ai",
    "cli",
    "coding-agent"
  ],
  "type": "module",
  "bin": {
    "codev": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun --hot src/index.tsx",
    "build": "bun build.ts",
    "start": "node dist/index.js",
    "test": "bun test",
    "typecheck": "bunx --bun tsc --noEmit",
    "check": "bunx --bun @biomejs/biome check",
    "fix": "bunx --bun @biomejs/biome check --write",
    "prepare": "husky",
    "prepublishOnly": "bun check && bun typecheck && bun test && bun run build",
    "prepack": "mv README.md .readme-repo.bak && mv README.npm.md README.md",
    "postpack": "mv README.md README.npm.md && mv .readme-repo.bak README.md"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "bun fix",
      "bun typecheck"
    ]
  },
  "dependencies": {
    "ink": "^7.0.1",
    "ink-spinner": "^5.0.0",
    "open": "^11.0.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "^1.3.12",
    "@types/react": "^19.2.14",
    "husky": "^9.1.7",
    "ink-testing-library": "^4.0.0",
    "lint-staged": "^16.4.0",
    "typescript": "^6.0.3"
  }
}
